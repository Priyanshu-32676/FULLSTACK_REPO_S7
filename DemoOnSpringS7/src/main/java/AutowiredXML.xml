<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.1.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context-3.1.xsd">
         
         <!--  Create a bean for Engine class -->
         <bean id ="engine" class="DemoOnSpring.DemoOnSpringS7.AutowiredXMLEngineClass"/>
         <!-- Create a bean for car class -->
         <bean id="car" class ="DemoOnSpring.DemoOnSpringS7.AutowiredXMLCarClass" autowire="byName"/><!-- byname is automatically will become engine because the bean name and property name should must be same -->
         
         
         </beans>
